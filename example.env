# NITK Academic Advisor Configuration
# =================================

# API Configuration
# =================
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=true

# Gemini API Configuration
# ========================
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
GEMINI_MODEL=gemini-2.0-flash-exp

# Document Processing Configuration
# =================================
# Chunking parameters for academic PDFs
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
INGEST_VERSION=v2

# Model Configuration
# ===================
EMBEDDING_MODEL=intfloat/e5-base-v2
EMBEDDING_DIM=768
CROSS_ENCODER_MODEL=BAAI/bge-reranker-large



# Retrieval Configuration
# =======================
# Top-K parameters for different retrieval stages
TOP_K_VECTOR=50
TOP_K_BM25=50
TOP_K_HYBRID=100
TOP_K_RERANK=20
FINAL_TOP_K=10  # Controls number of final sources returned

# Hybrid retrieval weights (BM25 weight, vector weight = 1-alpha)
HYBRID_ALPHA=0.3

# Batch processing
BATCH_SIZE_EMBEDDING=16

# Confidence thresholds
MIN_CONFIDENCE_THRESHOLD=0.3
HIGH_CONFIDENCE_THRESHOLD=0.8

# File Paths
# ==========
DATA_DIR=data
PDF_DIR=data/pdfs
CHUNKS_FILE=data/chunks_documents_v2.ndjson
BM25_INDEX_FILE=data/bm25_index.pkl

# Optional FAISS override paths (defaults are fine for most setups)
# FAISS_INDEX_FILE=data/faiss_storage/documents_v2_index.bin
# FAISS_METADATA_FILE=data/faiss_storage/documents_v2_metadata.pkl

# PDF URLs (optional auto-download if PDFs are missing)
# ================================================
BTECH_PDF_URL=https://www.nitk.ac.in/document/attachments/8305/Btech_Curriculum_2023.pdf
PG_PDF_URL=https://www.nitk.ac.in/document/attachments/8306/PG_Curriculum_2023.pdf

# Logging Configuration
# =====================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Performance Configuration
# =========================
# Request timeout (seconds)
REQUEST_TIMEOUT=30
# Response timeout (seconds)
RESPONSE_TIMEOUT=60
