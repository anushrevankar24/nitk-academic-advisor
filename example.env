# NITK Academic Advisor — Configuration Template
# ================================================
# Copy this file to .env and fill in your values.
# Lines starting with # are comments and are ignored.

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=true

# ── LLM — OpenRouter ─────────────────────────────────────────────────────────
# Get a free key at https://openrouter.ai
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"

# Model to use via OpenRouter (default = Gemini 2.0 Flash, free tier)
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Embedding & Reranking Models ──────────────────────────────────────────────
EMBEDDING_MODEL=intfloat/e5-base-v2
EMBEDDING_DIM=768
CROSS_ENCODER_MODEL=BAAI/bge-reranker-large

# ── Document Ingestion ────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
INGEST_VERSION=v2

# ── Retrieval Parameters ──────────────────────────────────────────────────────
TOP_K_VECTOR=50         # candidates from FAISS
TOP_K_BM25=50           # candidates from BM25
TOP_K_HYBRID=100        # merged pool after RRF fusion
TOP_K_RERANK=20         # after cross-encoder reranking
FINAL_TOP_K=10          # final chunks sent to LLM (= sources returned)

# BM25 vs vector weight (0.0 = pure vector, 1.0 = pure BM25)
HYBRID_ALPHA=0.3

# MMR diversity (higher = more relevance, lower = more diversity)
MMR_LAMBDA=0.7

# Batch size for embedding (reduce if you run out of RAM)
BATCH_SIZE_EMBEDDING=16

# ── Confidence Thresholds ─────────────────────────────────────────────────────
MIN_CONFIDENCE_THRESHOLD=0.3
HIGH_CONFIDENCE_THRESHOLD=0.8

# ── File Paths ────────────────────────────────────────────────────────────────
DATA_DIR=data
PDF_DIR=data/pdfs
CHUNKS_FILE=data/chunks_documents_v2.ndjson
BM25_INDEX_FILE=data/bm25_index.pkl
# FAISS_INDEX_FILE=data/faiss_storage/documents_v2_index.bin
# FAISS_METADATA_FILE=data/faiss_storage/documents_v2_metadata.pkl

# ── Optional PDF Auto-Download ────────────────────────────────────────────────
# If set, the ingestion script will download the PDFs automatically if missing.
BTECH_PDF_URL=https://www.nitk.ac.in/document/attachments/8305/Btech_Curriculum_2023.pdf
PG_PDF_URL=https://www.nitk.ac.in/document/attachments/8306/PG_Curriculum_2023.pdf

# ── Logging & Timeouts ────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
REQUEST_TIMEOUT=30
RESPONSE_TIMEOUT=60
